# API 베이스 URL (비우면 동일 출처 / Vite 프록시 사용)
# VITE_API_URL=http://localhost:3000
# 배포된 백엔드(Render): https://order-app-backend-is6m.onrender.com
# (프로덕션 빌드 기본값은 ui/.env.production 의 VITE_API_URL 참고)

# 서버 .env 의 ADMIN_API_KEY 와 동일한 값 (관리자 탭 API 호출 시 X-Admin-Key 로 전달)
# 값을 바꾼 뒤에는 Vite 개발 서버를 재시작해야 합니다.
# VITE_ADMIN_API_KEY=your-secret-key
