# 서버
PORT=3000
# 프런트엔드(Vite 등) 주소 — CORS 허용용
CORS_ORIGIN=http://localhost:5173

# JSON 본문 최대 크기 (기본 100kb)
# JSON_BODY_LIMIT=512kb

# 분당 /api 요청 한도 (기본 120)
# API_RATE_LIMIT_PER_MINUTE=120

# 관리자 API (/api/admin/*). 프로덕션에서는 반드시 설정하세요.
# 개발 시 비워 두면 관리자 API가 인증 없이 열립니다(콘솔 경고).
# 설정 시 UI에는 같은 값을 VITE_ADMIN_API_KEY 로 넣어야 합니다.
ADMIN_API_KEY=

# PostgreSQL — 연결 문자열 한 줄 (권장)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# 또는 개별 변수
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=coffee_order_db
